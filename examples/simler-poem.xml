        <title>Johann Wilhelm Simler, Teutsche Gedichte (C, 1663) — rendering sample</title>
        <author><persName ref="http://d-nb.info/gnd/119151693">Johann Wilhelm Simler</persName></author>
      </titleStmt>
      <publicationStmt><p>Simler Digital — illustrative sample for the ODD-to-static PoC.</p></publicationStmt>
      <sourceDesc><bibl><idno type="URLIIIF">https://www.e-rara.ch/i3f/v20/4049159/manifest</idno></bibl></sourceDesc>
    </fileDesc>
